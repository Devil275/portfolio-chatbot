# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Server Configuration
PORT=3000
NODE_ENV=development

# LinkedIn API Configuration
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_DEVELOPER_TOKEN=your-developer-token

# Portfolio Configuration
PORTFOLIO_URL=https://devil275.github.io/raj-shekhar-portfolio/
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/raj-shekhar-255131300/

# Database Configuration (Optional)
DATABASE_URL=your-database-url

# Webhook Configuration
WEBHOOK_URL=https://your-domain.com/webhook/linkedin

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=*
